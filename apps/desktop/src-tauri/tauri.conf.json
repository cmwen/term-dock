{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Term Dock",
  "version": "0.1.0",
  "identifier": "dev.termdock.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Term Dock",
        "width": 1180,
        "height": 760,
        "minWidth": 820,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "deep-link": { "desktop": { "schemes": ["term-dock"] } }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/icon.png"] }
}
